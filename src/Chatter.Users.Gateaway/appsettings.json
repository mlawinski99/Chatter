{
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/chatter",
    "Audience": "account",
    "RequireHttpsMetadata": "false"
  },
  "RateLimit": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "Gateaway": {
    "Routes": {
      "usersRegisterRoute": {
        "ClusterId": "usersCluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/users/register"
        }
      },
      "usersLoginRoute": {
        "ClusterId": "usersCluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/users/login"
        }
      },
      "usersAuthenticatedRoute": {
        "ClusterId": "usersCluster",
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "usersCluster": {
        "Destinations": {
          "users": {
            "Address": "http://localhost:5141/"
          }
        }
      }
    }
  }
}