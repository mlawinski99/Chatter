{
  "Keycloak": {
    "AuthServerUrl": "http://localhost:8080",
    "Realm": "chatter",
    "ClientId": "syncjob",
    "ClientSecret": "NBWxS3ZZCBH5CDDrRJPLiqhWmR6pAOdw",
    "UseServiceAccount": true,
    "ConnectionStrings": {
      "MessagesDb": "Host=localhost;Port=5432;Database=MessagesDb;Username=postgres;Password=postgres"
    }
  },
  "Elasticsearch": {
    "Uri": "http://localhost:9200",
    "IndexFormat": "user-sync-logs-{0:yyyy.MM.dd}"
  },

  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Elasticsearch"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Elasticsearch",
        "Args": {
          "nodeUris": "http://localhost:9200",
          "indexFormat": "user-sync-logs-{0:yyyy.MM.dd}",
          "autoRegisterTemplate": true,
          "typeName": "_doc",
          "batchPostingLimit": 50,
          "period": "00:00:05"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ],
    "Properties": {
      "Application": "KeycloakUserSyncService"
    }
  }
}