{
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/chatter",
    "Audience": "account",
    "RequireHttpsMetadata": "false"
  },
  "RateLimit": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "Gateaway": {
    "Routes": {
      "messagesRoute": {
        "ClusterId": "messagesCluster",
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "messagesCluster": {
        "Destinations": {
          "messages": {
            "Address": "http://localhost:5160/"
          }
        }
      }
    }
  }
}